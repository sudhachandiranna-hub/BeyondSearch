OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

SERPAPI_API_KEY=your_serpapi_key_here
# Optional. Blank SERPAPI_REGION = no country bias (was hardcoded to "in"
# before). Set e.g. "us" if your users/docs are US-centric.
SERPAPI_REGION=
SERPAPI_LANG=en

GOOGLE_SHEETS_CREDENTIALS_FILE=credentials/google_service_account.json
GOOGLE_SHEETS_SPREADSHEET_ID=

LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=ai-research-assistant

APP_ENV=development
KNOWLEDGE_AGENT_TIMEOUT_SECONDS=30
RESEARCH_AGENT_TIMEOUT_SECONDS=45
RECORDING_AGENT_TIMEOUT_SECONDS=15
SQLITE_DB_PATH=data/app.db
ANSWER_FILES_DIR=data/answers
